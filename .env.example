# ──────────────────────────────────────────────
# ThreatScan Environment Configuration
# ──────────────────────────────────────────────

# ── General ──
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=threatscan
POSTGRES_USER=threatscan
POSTGRES_PASSWORD=threatscan_secret_change_me

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── MinIO / S3 ──
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret_change_me
MINIO_BUCKET=threatscan-files
MINIO_USE_SSL=false

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
MAX_UPLOAD_SIZE_MB=50
RATE_LIMIT_PER_MINUTE=30
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://threatscan-nine.vercel.app
ADMIN_PASSWORD=change-me-admin-password

# ── Celery ──
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_TIMEOUT=300

# ── Frontend ──
NEXT_PUBLIC_API_URL=https://your-api-domain
NEXT_PUBLIC_APP_NAME=ThreatScan
